datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Role {
  SUPERADMIN
  TENANT
}

enum RequestType {
  CALL_WAITER
  REQUEST_BILL
}

enum RequestStatus {
  PENDING
  ARCHIVED
}

enum Plan {
  FREE
  PRO
}

model User {
  id        String      @id @default(cuid())
  name      String?
  email     String      @unique
  password  String?
  role      Role        @default(TENANT)
  restaurant Restaurant?
  createdAt DateTime    @default(now())
}

model Restaurant {
  id              String         @id @default(cuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  slug            String         @unique
  wifiSsid        String?
  wifiPassword    String?
  googleReviewUrl String?
  instagramUrl    String?
  facebookUrl     String?
  tiktokUrl       String?
  whatsappUrl     String?
  currency        String         @default("USD")
  uiLanguage      String         @default("en")
  languages       String[]       @default(["en"])
  isActive        Boolean        @default(true)
  logoUrl         String?
  city            String?
  country         String?
  tablesCount            Int                  @default(0)
  plan                   Plan                 @default(FREE)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionStatus     String?
  menus                  Menu[]
  leads           CustomerLead[]
  feedbacks       Feedback[]
  tableRequests   TableServiceRequest[]
  createdAt       DateTime             @default(now())

  @@index([isActive])
}

model TableServiceRequest {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableNumber  String
  type         RequestType
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  @@index([restaurantId, status, createdAt])
}

model Menu {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         Json
  isActive     Boolean    @default(true)
  items        MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id            String  @id @default(cuid())
  menuId        String
  menu          Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name          Json
  description   Json       @default("{}")
  price         Float
  images        String[]   @default([])
  isAvailable   Boolean @default(true)

  @@index([menuId])
}

model CustomerLead {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  email        String
  source       String     @default("WIFI_UNLOCK")
  emailSent    Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([emailSent, createdAt])
}

model Feedback {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}
